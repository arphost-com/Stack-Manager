# Stack Manager Configuration

# Setup will replace change-me values with generated random secrets.

# Required: API key for authentication
API_KEY=change-me-to-a-secure-key

# Bootstrap web login. If ADMIN_PASSWORD is unset, the first admin password
# defaults to API_KEY when the MariaDB users table is empty.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-to-a-different-secure-password

# MariaDB and Redis persistent data are stored under STATE_DIR.
DB_NAME=stack_manager
DB_USER=stack_manager
DB_PASSWORD=change-me-to-a-secure-database-password
DB_ROOT_PASSWORD=change-me-to-a-secure-root-database-password
REDIS_PASSWORD=change-me-to-a-secure-redis-password
REDIS_DB=0
CACHE_TTL_SECONDS=15
METRICS_REFRESH_MINUTES=15
WARM_CACHE_TTL_MINUTES=30

# Docker projects root directory on this host. Set this to the directory that
# contains the Compose projects you want Stack Manager to manage.
DOCKER_ROOT=/path/to/compose-projects

# Stack Manager persistent state directory, relative to this Stack Manager
# root by default.
# Run ./scripts/prepare-state.sh .env before docker compose up so Docker does
# not create this path as root.
STATE_DIR=.stack-manager

# Host path mounted into the server container at /backup-targets for local,
# CIFS, NFS, and other Linux mount backup endpoints.
BACKUP_TARGET_ROOT=.stack-manager/backup-targets

# Server runs non-root by default. Set DOCKER_GID to the host docker socket group:
# stat -c '%g' /var/run/docker.sock
DOCKER_GID=998

# Host Docker daemon configuration directory. Docker Settings writes
# daemon.json here through a short-lived Docker helper container.
DOCKER_DAEMON_DIR=/etc/docker

# UID:GID that should own STATE_DIR and run the server container.
# Use the numeric user and group ID that should manage Docker on this host.
# Examples: 0:0, 1000:1000, 998:998
SERVER_USER=1000:1000

# Web UI host ports. The default install serves HTTPS on WEB_SSL_PORT with a
# self-signed cert; WEB_HTTP_PORT only serves the redirect to HTTPS and
# Let's Encrypt HTTP-01 challenge files. To use Let's Encrypt end-to-end,
# set these to 80 and 443 (requires the host be reachable on those ports
# from the internet on a real domain).
WEB_HTTP_PORT=8193
WEB_SSL_PORT=8993

# SSL bootstrap. On first boot the web container generates a self-signed
# cert in ${STATE_DIR}/ssl/ with SANs covering the hostname and localhost.
# SSL_CN overrides the certificate common name; SSL_EXTRA_SANS is a
# comma-separated list of extra hostnames or IPs (e.g. "vpn.example.com,10.0.0.5").
# The Settings > SSL panel can regenerate the cert or hand off to
# Let's Encrypt without editing these directly.
SSL_CN=
SSL_EXTRA_SANS=
SSL_SELF_SIGNED_DAYS=3650

# Public/local dashboard URL shown after setup. Edit if hostname detection is
# not the URL users should open.
HOST_URL=https://change-me:8993

# Prefix prepended to every Docker Hub base image referenced in this repo
# (Dockerfiles FROM lines, docker-compose image: refs, and runtime alpine
# helper containers). Leave empty to pull base images directly from Docker
# Hub. Set this on hosts with a caching Docker Hub mirror or a GitLab
# dependency proxy to eliminate Docker Hub rate-limit exposure during
# builds. It MUST end with a trailing slash. Example for the ARPHost
# GitLab dependency proxy:
#   BASE_IMAGE_PREFIX=10.10.10.96:8929/arphost/dependency_proxy/containers/library/
BASE_IMAGE_PREFIX=
