# Compose Manager Configuration

# Required: API key for authentication
API_KEY=change-me-to-a-secure-key

# Docker projects root directory on the host
DOCKER_ROOT=/home/debian/docker

# Server runs non-root by default. Set DOCKER_GID to the host docker socket group:
# stat -c '%g' /var/run/docker.sock
DOCKER_GID=998

# Optional override for hosts that intentionally run compose management as root
# SERVER_USER=0:0
SERVER_USER=1001:1001

# Web UI host port
WEB_PORT=8193
